<Window x:Class="ATS_WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ATS_WPF.ViewModels"
        xmlns:models="clr-namespace:ATS_WPF.Models"
        xmlns:controls="clr-namespace:ATS_WPF.Views.Controls"
        mc:Ignorable="d"
        Title="ATS Weight System" Height="900" Width="1200"
        WindowStartupLocation="CenterScreen" Background="#FFF5F5F5"
        Icon="pack://application:,,,/Assets/AVL_Icon.ico">
    
    <Window.Resources>
        
        <Style TargetType="Button" x:Key="HeaderButton">
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="1"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#FF95A5A6"/>
                                <Setter Property="Foreground" Value="#FFBDC3C7"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
            <!-- Bool → Visibility converter for the axle toggle row -->
            <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
        </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Settings -->
            <RowDefinition Height="*"/>    <!-- Main Content -->
            <RowDefinition Height="Auto"/> <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#FF2C3E50" Padding="20,15">
            <Border.Effect>
                <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" Opacity="0.3"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Status Items Left (Logo, CAN Bitrate) -->
                    <ColumnDefinition Width="*"/>    <!-- Center (Operation Buttons) -->
                    <ColumnDefinition Width="Auto"/> <!-- Status Items Right (Status, ADC, Rate) -->
                </Grid.ColumnDefinitions>
                
                <!-- Left Section: Logo and CAN Info -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#FF34495E" CornerRadius="2" Padding="4" Margin="0,0,15,0">
                        <TextBlock Text="AVL ⚙" Foreground="White" FontSize="10" FontWeight="Bold"/>
                    </Border>
                    <TextBlock Text="{Binding Connection.SelectedBaudRate, StringFormat='CAN: {0}'}" 
                               Foreground="White" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13"/>
                </StackPanel>

                <!-- Center Section: Operation Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="{Binding Connection.ConnectionButtonText}" Command="{Binding Connection.ConnectCommand}" 
                            Style="{StaticResource HeaderButton}"
                            Background="{Binding Connection.ConnectionButtonColor}"
                            Margin="0,0,8,0"/>
                    
                    <Button Content="▶ Start Stream" Command="{Binding Connection.StartStreamCommand}"
                            Style="{StaticResource HeaderButton}"
                            Background="#FF28A745"
                            Margin="0,0,8,0"/>
                    
                    <Button Content="⏹ Stop All" Command="{Binding StopAllCommand}"
                            Style="{StaticResource HeaderButton}"
                            Background="#FFDC3545"
                            Margin="0,0,8,0"/>
                    
                    <Button Content="⚙ Settings" Command="{Binding OpenSettingsCommand}"
                            Style="{StaticResource HeaderButton}"
                            Background="#FF7F8C8D"
                            Margin="0,0,8,0"/>
                    
                    <Button x:Name="ToolsButton" Content="🔧 Tools"
                            Click="ToolsButton_Click"
                            Style="{StaticResource HeaderButton}"
                            Background="#FF7F8C8D">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Configuration Viewer" Command="{Binding OpenConfigViewerCommand}"/>
                                <Separator/>
                                <MenuItem Header="Bootloader Manager" Command="{Binding OpenBootloaderCommand}"/>
                                <MenuItem Header="Monitor Window" Command="{Binding OpenMonitorCommand}"/>
                                <MenuItem Header="Logs Window" Command="{Binding OpenLogsCommand}"/>
                                <MenuItem Header="Status History" Command="{Binding OpenStatusHistoryCommand}"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>

                <!-- Right Section: Status and Rate Selector -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Connectivity:" Foreground="#FFBDC3C7" Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <Ellipse Width="10" Height="10" Fill="{Binding Connection.StatusColor}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Connection.ConnectionStatusText}" Foreground="White" FontWeight="SemiBold" Margin="0,0,15,0" VerticalAlignment="Center"/>

                    <TextBlock Text="Mode:" Foreground="#FFBDC3C7" Margin="15,0,8,0" VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding AvailableVehicleModes}" 
                              SelectedItem="{Binding SelectedVehicleMode}"
                              Width="110" Height="24" Padding="5,0" VerticalContentAlignment="Center"
                              Margin="0,0,15,0"/>

                    <TextBlock Text="Rate:" Foreground="#FFBDC3C7" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding Connection.StreamingRates}" 
                              SelectedItem="{Binding Connection.SelectedStreamingRate}"
                              Width="75" Height="24" Padding="5,0" VerticalContentAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
        <!-- Main Content -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                 <!-- Operational Area: Live Weight Data & Controls -->
                 <GroupBox Header="Live Weight Data" Margin="0,0,0,20" Padding="10">
                     <StackPanel>
                         <!-- Left / Right Axle Toggle — only visible for LMV / HMV -->
                         <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                     Margin="0,0,0,10"
                                     Visibility="{Binding IsMultiAxleMode, Converter={StaticResource BoolToVisConverter}}">
                             <Button Content="◀  Left Axle"
                                     Command="{Binding SelectLeftAxleCommand}"
                                     Width="130" Height="32" Margin="0,0,4,0"
                                     FontWeight="SemiBold" FontSize="13" Cursor="Hand"
                                     BorderThickness="2">
                                 <Button.Style>
                                     <Style TargetType="Button">
                                         <Setter Property="Background" Value="#FFE0E0E0"/>
                                         <Setter Property="Foreground" Value="#FF2C3E50"/>
                                         <Setter Property="BorderBrush" Value="#FFC0C0C0"/>
                                         <Setter Property="Template">
                                             <Setter.Value>
                                                 <ControlTemplate TargetType="Button">
                                                     <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                             BorderBrush="{TemplateBinding BorderBrush}"
                                                             BorderThickness="{TemplateBinding BorderThickness}"
                                                             CornerRadius="6,0,0,6" Padding="10,4">
                                                         <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                     </Border>
                                                 </ControlTemplate>
                                             </Setter.Value>
                                         </Setter>
                                         <Style.Triggers>
                                             <DataTrigger Binding="{Binding IsLeftActive}" Value="True">
                                                 <Setter Property="Background" Value="#FF2980B9"/>
                                                 <Setter Property="Foreground" Value="White"/>
                                                 <Setter Property="BorderBrush" Value="#FF1A5E8C"/>
                                             </DataTrigger>
                                         </Style.Triggers>
                                     </Style>
                                 </Button.Style>
                             </Button>
                             <Button Content="Right Axle  ▶"
                                     Command="{Binding SelectRightAxleCommand}"
                                     Width="130" Height="32" Margin="4,0,0,0"
                                     FontWeight="SemiBold" FontSize="13" Cursor="Hand"
                                     BorderThickness="2">
                                 <Button.Style>
                                     <Style TargetType="Button">
                                         <Setter Property="Background" Value="#FFE0E0E0"/>
                                         <Setter Property="Foreground" Value="#FF2C3E50"/>
                                         <Setter Property="BorderBrush" Value="#FFC0C0C0"/>
                                         <Setter Property="Template">
                                             <Setter.Value>
                                                 <ControlTemplate TargetType="Button">
                                                     <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                             BorderBrush="{TemplateBinding BorderBrush}"
                                                             BorderThickness="{TemplateBinding BorderThickness}"
                                                             CornerRadius="0,6,6,0" Padding="10,4">
                                                         <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                     </Border>
                                                 </ControlTemplate>
                                             </Setter.Value>
                                         </Setter>
                                         <Style.Triggers>
                                             <DataTrigger Binding="{Binding IsRightActive}" Value="True">
                                                 <Setter Property="Background" Value="#FF27AE60"/>
                                                 <Setter Property="Foreground" Value="White"/>
                                                 <Setter Property="BorderBrush" Value="#FF1A7A42"/>
                                             </DataTrigger>
                                         </Style.Triggers>
                                     </Style>
                                 </Button.Style>
                             </Button>
                         </StackPanel>

                         <!-- Single Dashboard — bound to ActiveAxle -->
                         <controls:DashboardPanel DataContext="{Binding ActiveAxle.Dashboard}"/>
                         <controls:CalibrationPanel DataContext="{Binding ActiveAxle.Calibration}" Margin="0,10,0,0"/>
                     </StackPanel>
                 </GroupBox>

                 <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- System Status -->
                    <controls:SystemStatusPanel Grid.Column="0" DataContext="{Binding SystemStatus}" Margin="0,0,10,0"/>
                    
                    <!-- Data Logging -->
                    <controls:LoggingPanel Grid.Column="1" DataContext="{Binding Logging}" Margin="10,0,0,0"/>
                 </Grid>
            </StackPanel>
        </ScrollViewer>
        
        <!-- Status Bar -->
        <controls:AppStatusBar Grid.Row="3" DataContext="{Binding StatusBar}"/>
        
    </Grid>
</Window>
